{
  "info": {
    "name": "PTIT CNTT1 IT211 Session13 - Employee API",
    "description": "Postman Collection for Employee Management API QA.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get all employees",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/employees"
      }
    },
    {
      "name": "Create employee",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Le Van C\",\n  \"department\": \"Finance\",\n  \"salary\": 13000000\n}"
        },
        "url": "{{baseUrl}}/api/employees"
      }
    },
    {
      "name": "Get employee by id",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/employees/{{employeeId}}"
      }
    },
    {
      "name": "Update employee",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Le Van C Updated\",\n  \"department\": \"Finance\",\n  \"salary\": 15000000\n}"
        },
        "url": "{{baseUrl}}/api/employees/{{employeeId}}"
      }
    },
    {
      "name": "Delete employee",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": "{{baseUrl}}/api/employees/{{employeeId}}"
      }
    },
    {
      "name": "Get employee not found",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/employees/999"
      }
    },
    {
      "name": "Create employee invalid fullName",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"\",\n  \"department\": \"Finance\",\n  \"salary\": 13000000\n}"
        },
        "url": "{{baseUrl}}/api/employees"
      }
    },
    {
      "name": "Create employee invalid salary",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Invalid Salary\",\n  \"department\": \"Finance\",\n  \"salary\": 0\n}"
        },
        "url": "{{baseUrl}}/api/employees"
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "employeeId",
      "value": "1"
    }
  ]
}
